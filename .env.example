# Copy to .env and fill in from your Supabase project (Settings -> API).
# These are EXPO_PUBLIC_* so they're inlined into the client at build time.
# The anon key is meant to be public; row-level security is what protects data.
# Leave them unset to run the app fully local (all cloud UI hides).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
