{
  "expo": {
    "name": "Vault",
    "slug": "vault-app",
    "version": "1.0.0",
    "scheme": "vault",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0e0f13",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.talktofess.vault",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock your vault with Face ID.",
        "NSPhotoLibraryUsageDescription": "Import photos and videos into your vault."
      }
    },
    "android": {
      "package": "com.talktofess.vault",
      "versionCode": 1,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bdd2dd8b-dd9c-4917-bba8-1d6edd30e51e",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bdd2dd8b-dd9c-4917-bba8-1d6edd30e51e"
      }
    },
    "owner": "f3s7us"
  }
}
