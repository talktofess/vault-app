{
  "expo": {
    "name": "Offline Chess",
    "slug": "vault-app",
    "version": "1.3.0",
    "scheme": "vault",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0e0f13",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0f13"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.talktofess.vault",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock to continue.",
        "NSPhotoLibraryUsageDescription": "Import photos and videos.",
        "NSPhotoLibraryAddUsageDescription": "Manage imported media."
      }
    },
    "android": {
      "package": "com.talktofess.vault",
      "versionCode": 7,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0f13"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-media-library",
        {
          "photosPermission": "Import photos and videos.",
          "savePhotosPermission": "Manage imported media.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Capture photos directly into the app."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bdd2dd8b-dd9c-4917-bba8-1d6edd30e51e",
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bdd2dd8b-dd9c-4917-bba8-1d6edd30e51e"
      }
    },
    "owner": "f3s7us"
  }
}
